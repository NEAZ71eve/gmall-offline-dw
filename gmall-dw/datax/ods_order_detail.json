
{
    "job": {
        "content": [
            {
                "reader": {
                    "name": "mysqlreader",
                    "parameter": {
                        "column": ["id", "order_id", "sku_id", "sku_name", "img_url", "order_price", "sku_num", "create_time", "source_type", "source_id"],
                        "connection": [{"jdbcUrl": ["jdbc:mysql://localhost:3307/gmall"], "table": ["order_detail"]}],
                        "password": "000000",
                        "username": "root",
                        "where": "create_time >= '${dt}' 00:00:00 AND create_time < '${dt}' 23:59:59"
                    }
                },
                "writer": {
                    "name": "hdfswriter",
                    "parameter": {
                        "column": [{"name": "id", "type": "string"}, {"name": "order_id", "type": "string"}, {"name": "sku_id", "type": "string"}, {"name": "sku_name", "type": "string"}, {"name": "img_url", "type": "string"}, {"name": "order_price", "type": "decimal(16,2)"}, {"name": "sku_num", "type": "bigint"}, {"name": "create_time", "type": "string"}, {"name": "source_type", "type": "string"}, {"name": "source_id", "type": "string"}],
                        "compress": "gzip",
                        "defaultFS": "hdfs://localhost:9000",
                        "fieldDelimiter": "\\t",
                        "fileName": "order_detail",
                        "fileType": "text",
                        "path": "/origin_data/gmall/db/order_detail_inc/${dt}",
                        "writeMode": "append"
                    }
                }
            }
        ],
        "setting": {"speed": {"channel": "3"}}
    }
}
