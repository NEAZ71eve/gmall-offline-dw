CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_tmp_dir=/hadoop/tmp
HDFS_CONF_dfs_replication=2
HDFS_CONF_dfs_permissions_enabled=false
HDFS_CONF_dfs_namenode_name_dir=/hadoop/dfs/name
HDFS_CONF_dfs_datanode_data_dir=/hadoop/dfs/data
YARN_CONF_yarn_resourcemanager_hostname=resourcemanager
YARN_CONF_yarn_nodemanager_resource_memory_mb=2048
YARN_CONF_yarn_scheduler_maximum_allocation_mb=2048
YARN_CONF_yarn_nodemanager_resource_cpu_vcores=2
MAPRED_CONF_mapreduce_framework_name=yarn
MAPRED_CONF_yarn_app_mapreduce_am_resource_mb=1024
MAPRED_CONF_mapreduce_map_memory_mb=1024
MAPRED_CONF_mapreduce_reduce_memory_mb=1024
