{
    "job": {
        "content": [
            {
                "reader": {
                    "name": "mysqlreader",
                    "parameter": {
                        "column": [
                            "id",
                            "consignee",
                            "consignee_tel",
                            "total_amount",
                            "order_status",
                            "user_id",
                            "payment_way",
                            "delivery_address",
                            "order_comment",
                            "out_trade_no",
                            "trade_body",
                            "create_time",
                            "operate_time",
                            "expire_time",
                            "tracking_no",
                            "parent_order_id",
                            "img_url",
                            "province_id",
                            "benefit_reduce_amount",
                            "original_total_amount",
                            "feight_fee"
                        ],
                        "connection": [
                            {
                                "jdbcUrl": [
                                    "jdbc:mysql://localhost:3307/gmall"
                                ],
                                "table": [
                                    "order_info"
                                ]
                            }
                        ],
                        "password": "testpass",
                        "username": "testuser",
                        "where": "create_time >= '${start_time}' and create_time < '${end_time}'"
                    }
                },
                "writer": {
                    "name": "hdfswriter",
                    "parameter": {
                        "column": [
                            {"name": "id", "type": "string"},
                            {"name": "consignee", "type": "string"},
                            {"name": "consignee_tel", "type": "string"},
                            {"name": "total_amount", "type": "decimal"},
                            {"name": "order_status", "type": "string"},
                            {"name": "user_id", "type": "string"},
                            {"name": "payment_way", "type": "string"},
                            {"name": "delivery_address", "type": "string"},
                            {"name": "order_comment", "type": "string"},
                            {"name": "out_trade_no", "type": "string"},
                            {"name": "trade_body", "type": "string"},
                            {"name": "create_time", "type": "string"},
                            {"name": "operate_time", "type": "string"},
                            {"name": "expire_time", "type": "string"},
                            {"name": "tracking_no", "type": "string"},
                            {"name": "parent_order_id", "type": "string"},
                            {"name": "img_url", "type": "string"},
                            {"name": "province_id", "type": "string"},
                            {"name": "benefit_reduce_amount", "type": "decimal"},
                            {"name": "original_total_amount", "type": "decimal"},
                            {"name": "feight_fee", "type": "decimal"}
                        ],
                        "compress": "gzip",
                        "defaultFS": "hdfs://localhost:9000",
                        "fieldDelimiter": "\\t",
                        "fileName": "order_info",
                        "fileType": "text",
                        "path": "/warehouse/gmall/ods/ods_order_info/dt=${dt}",
                        "writeMode": "append"
                    }
                }
            }
        ],
        "setting": {
            "speed": {
                "channel": "1",
                "bytes": "10485760"
            }
        }
    }
}