{
    "job": {
        "content": [
            {
                "reader": {
                    "name": "mysqlreader",
                    "parameter": {
                        "column": [
                            "id",
                            "login_name",
                            "nick_name",
                            "name",
                            "phone_num",
                            "email",
                            "head_img",
                            "user_level",
                            "birthday",
                            "gender",
                            "create_time",
                            "operate_time",
                            "status"
                        ],
                        "connection": [
                            {
                                "jdbcUrl": [
                                    "jdbc:mysql://localhost:3307/gmall"
                                ],
                                "table": [
                                    "user_info"
                                ]
                            }
                        ],
                        "password": "testpass",
                        "username": "testuser",
                        "where": "create_time >= '${start_time}' and create_time < '${end_time}'"
                    }
                },
                "writer": {
                    "name": "hdfswriter",
                    "parameter": {
                        "column": [
                            {"name": "id", "type": "string"},
                            {"name": "login_name", "type": "string"},
                            {"name": "nick_name", "type": "string"},
                            {"name": "name", "type": "string"},
                            {"name": "phone_num", "type": "string"},
                            {"name": "email", "type": "string"},
                            {"name": "head_img", "type": "string"},
                            {"name": "user_level", "type": "string"},
                            {"name": "birthday", "type": "string"},
                            {"name": "gender", "type": "string"},
                            {"name": "create_time", "type": "string"},
                            {"name": "operate_time", "type": "string"},
                            {"name": "status", "type": "string"}
                        ],
                        "compress": "gzip",
                        "defaultFS": "hdfs://localhost:9000",
                        "fieldDelimiter": "\\t",
                        "fileName": "user_info",
                        "fileType": "text",
                        "path": "/warehouse/gmall/ods/ods_user_info/dt=${dt}",
                        "writeMode": "append"
                    }
                }
            }
        ],
        "setting": {
            "speed": {
                "channel": "1",
                "bytes": "10485760"
            }
        }
    }
}